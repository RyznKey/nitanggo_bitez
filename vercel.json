{
  "version": 2,
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0",
      "config": {
        "maxDuration": 10,
        "includeFiles": [
          "app/**",
          "bootstrap/**",
          "config/**",
          "database/**",
          "public/index.php",
          "resources/**",
          "routes/**",
          "storage/framework/sessions/**",
          "storage/framework/views/**",
          "storage/framework/cache/data/**",
          "vendor/autoload.php",
          "vendor/composer/**",
          "vendor/laravel/framework/src/Illuminate/Foundation/helpers.php"
        ]
      }
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/(assets|images|img|svg|fonts|photos)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_KEY" : "base64:TirKQ2nBq0F7NNZ0H9ypy1zcfmeDuKL6Ti7pg+1v2AM=",
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "LOG_CHANNEL": "stderr",
    "SESSION_DRIVER": "cookie",
    "CACHE_STORE": "array",
    "SESSION_SECURE_COOKIE": "true",
    "DB_CONNECTION": "pgsql",
    "APP_CONFIG_CACHE": "/tmp/config.php",
    "APP_EVENTS_CACHE": "/tmp/events.php",
    "APP_PACKAGES_CACHE": "/tmp/packages.php",
    "APP_ROUTES_CACHE": "/tmp/routes.php",
    "APP_SERVICES_CACHE": "/tmp/services.php",
    "VIEW_COMPILED_PATH": "/tmp/views"
  }
}